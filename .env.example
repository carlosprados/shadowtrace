# ShadowTrace configuration (copy to .env or ~/.config/shadowtrace.env)

# Optional presentation
APP_NAME=ShadowTrace
LOCATION_TAG=

# Operating mode: "watch" (environment intrusion detection) or "presence" (legacy tracker)
MODE=watch

# Telegram (leave empty if not using Telegram alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Bluetooth scan (shared) ----
# Preferred adapter (e.g. hci1); empty = first available
BT_ADAPTER=
SCAN_INTERVAL_SECONDS=20
SCAN_WINDOW_SECONDS=8
SCAN_TRANSPORT=auto
CONTINUOUS_DISCOVERY=1

# ================= WATCH MODE (default) =================
# Only sightings at/above this RSSI count as "near/inside" (weaker = farther, e.g. neighbours)
WATCH_RSSI_MIN=-70
# Optional more permissive threshold during ALERT_HOURS (defaults to WATCH_RSSI_MIN)
WATCH_RSSI_MIN_NIGHT=-80
# Consecutive strong windows before a device counts as really present (filters passers-by)
WATCH_CONFIRM_HITS=2
# Seconds without a strong sighting before a present device is considered gone
WATCH_GONE_AFTER_SECONDS=120
# Learning window: every strong device seen during this time is added to the baseline
WATCH_LEARN_SECONDS=86400
# Minimum seconds between repeated alerts for the same device
ALERT_COOLDOWN_SECONDS=600
# Reinforced hours "start-end" (24h local), e.g. 0-7 or 22-6. Empty = disabled
ALERT_HOURS=
# MACs always treated as known/home (fixed-MAC devices), comma-separated
HOME_MACS=
# Learned baseline (editable) and forensic event log
BASELINE_FILE=~/.shadowtrace_baseline.json
EVENT_LOG=~/.shadowtrace_events.jsonl

# ---- Vendor OUI database ----
# Auto-downloaded/cached; refreshed when older than OUI_MAX_AGE_DAYS (0 = never)
OUI_FILE=~/.shadowtrace_oui.tsv
OUI_URL=https://www.wireshark.org/download/automated/data/manuf
OUI_MAX_AGE_DAYS=30
OUI_AUTO_UPDATE=1

# ---- Anomaly model (Python trains, Go infers) ----
ANOMALY_MODEL=~/.shadowtrace_anomaly.json

# ================= PRESENCE MODE (legacy) =================
# Comma-separated substrings; only matching device names will be tracked (optional)
NAME_WHITELIST=
# Comma-separated MAC addresses to ignore (e.g., AA:BB:CC:DD:EE:FF)
IGNORE_MACS=
GONE_AFTER_SECONDS=60
STATE_FILE=~/.shadowtrace_state.json
# Wi‑Fi presence: comma-separated hosts to ping (name@host or host)
WIFI_HOSTS=
# mDNS/Bonjour discovery (no prior IPs); requires avahi-browse
MDNS_DISCOVERY=1
# ARP discovery (no prior IPs); subnets auto-detected via `ip route` if unset
ARP_DISCOVERY=0
ARP_SUBNETS=
ARP_SWEEP=0
ARP_SWEEP_LIMIT=256
ARP_TIMEOUT_MS=500
